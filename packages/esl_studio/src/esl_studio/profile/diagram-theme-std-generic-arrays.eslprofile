					<reject link-dst-entity="same"
						description="Cannot make a direct {type} connection to the same entity"/>
				</connection>
				<context-menu menu="link"/>
			</def>

			<def category="link" type="Integer(*,*,*)" stroke="Green" stroke-width="4" draw="smart">
				<connection>
					<reject direction="output" dst-direction="output"
