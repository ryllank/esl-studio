				<ellipse width="5" height="4" stroke="none" stroke-width="1" fill="none"/>
				<option direction="input">
					<polygon stroke="Red" stroke-width="1" points="-10,-4 -20,0 -10,4" fill="Red"/>
				</option>
				<option sign="plus">
